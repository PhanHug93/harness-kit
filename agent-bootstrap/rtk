#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
RTK_VERSION="0.37.2"
RTK_BIN="${ROOT_DIR}/.tools/rtk/v${RTK_VERSION}/rtk"

if [ ! -x "${RTK_BIN}" ]; then
  echo "Pinned rtk v${RTK_VERSION} not found at ${RTK_BIN}." >&2
  echo "Run: ./scripts/install-rtk.sh" >&2
  exit 1
fi

exec "${RTK_BIN}" "$@"
