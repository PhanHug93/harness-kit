{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-bootstrap.local/schemas/agent-context-policy-v1.schema.json",
  "title": "Agent Context Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "version",
    "mode",
    "purpose",
    "required_context",
    "recommended_context",
    "protected_paths",
    "change_protocol",
    "agent_instructions"
  ],
  "properties": {
    "schema": {
      "const": "agent-context-policy/v1"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "enum": ["lite"]
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "required_context": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/relativePath"
      },
      "uniqueItems": true
    },
    "recommended_context": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/relativePath"
      },
      "uniqueItems": true
    },
    "protected_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["pattern", "reason"],
        "properties": {
          "pattern": {
            "$ref": "#/$defs/relativePathPattern"
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "change_protocol": {
      "type": "object",
      "additionalProperties": false,
      "required": ["preflight", "pre_edit", "pre_final", "rollback"],
      "properties": {
        "preflight": {
          "type": "string",
          "minLength": 1
        },
        "pre_edit": {
          "type": "string",
          "minLength": 1
        },
        "pre_final": {
          "type": "string",
          "minLength": 1
        },
        "rollback": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "agent_instructions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "allOf": [
        {
          "not": {
            "pattern": "^/"
          }
        },
        {
          "not": {
            "pattern": "(^|/)\\.\\.($|/)"
          }
        },
        {
          "not": {
            "pattern": "(^|/)\\.($|/)"
          }
        },
        {
          "not": {
            "pattern": "//"
          }
        },
        {
          "not": {
            "pattern": "/$"
          }
        },
        {
          "not": {
            "pattern": "[\\u0000-\\u001F]"
          }
        }
      ]
    },
    "relativePathPattern": {
      "type": "string",
      "minLength": 1,
      "allOf": [
        {
          "not": {
            "pattern": "^/"
          }
        },
        {
          "not": {
            "pattern": "(^|/)\\.\\.($|/)"
          }
        },
        {
          "not": {
            "pattern": "(^|/)\\.($|/)"
          }
        },
        {
          "not": {
            "pattern": "//"
          }
        },
        {
          "not": {
            "pattern": "/$"
          }
        },
        {
          "not": {
            "pattern": "[\\u0000-\\u001F]"
          }
        }
      ]
    }
  }
}
